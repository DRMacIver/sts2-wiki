---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map(event => ({
    params: { slug: event.id },
    props: { event },
  }));
}

const { event } = Astro.props;
---

<BaseLayout title={event.data.title}>
  <div class="card-detail">
    <div class="card-header">
      <a href={`${import.meta.env.BASE_URL}events/`} style="font-size: 0.85rem;">&larr; All Events</a>
      <h1>{event.data.title}</h1>
      {event.data.acts.length > 0 && (
        <div class="card-meta">{event.data.acts.join(', ')}</div>
      )}
    </div>

    {event.data.description_html && (
      <>
        <h2 style="margin-top: 1.5rem;">Description</h2>
        <div style="margin: 0.75rem 0;" set:html={event.data.description_html} />
      </>
    )}

    {event.data.options.length > 0 && (
      <>
        <h2 style="margin-top: 1.5rem;">Options</h2>
        <div style="margin-top: 0.5rem;">
          {event.data.options.map(opt => {
            const title = typeof opt === 'string' ? opt : opt.title;
            const desc = typeof opt === 'string' ? '' : opt.description;
            return (
              <div class="card-entry" style="margin-bottom: 0.5rem;">
                <h3 style="margin: 0; font-size: 1rem;">{title}</h3>
                {desc && <div class="card-meta" style="margin-top: 0.25rem;" set:html={desc} />}
              </div>
            );
          })}
        </div>
      </>
    )}

    {event.data.conditions && (
      <>
        <h2 style="margin-top: 1.5rem;">Conditions</h2>
        <p class="card-meta">{event.data.conditions}</p>
      </>
    )}
  </div>
</BaseLayout>

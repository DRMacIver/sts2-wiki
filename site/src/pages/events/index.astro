---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const filterOut = new Set(['DeprecatedEvent', 'TheArchitect']);
const allEvents = (await getCollection('events'))
  .filter(e => !filterOut.has(e.data.class_name));
const events = allEvents.sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<BaseLayout title="Events">
  <div class="page-header">
    <h1>Events</h1>
    <p class="subtitle">{events.length} random events</p>
  </div>

  <div class="card-grid">
    {events.map(event => (
      <a href={`${import.meta.env.BASE_URL}events/${event.id}/`} class="card-entry">
        <h3>{event.data.title}</h3>
        <div class="card-meta">
          {event.data.acts.length > 0 ? event.data.acts.join(', ') : 'Any act'}
        </div>
        {event.data.options.length > 0 && (
          <div class="card-meta" style="margin-top: 0.25rem;">
            {event.data.options.length} option{event.data.options.length > 1 ? 's' : ''}
          </div>
        )}
      </a>
    ))}
  </div>
</BaseLayout>

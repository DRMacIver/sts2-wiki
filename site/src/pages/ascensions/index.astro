---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const ascensions = (await getCollection('ascensions'))
  .sort((a, b) => a.data.level - b.data.level);

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Ascensions">
  <div class="page-header">
    <h1>Ascensions</h1>
    <p class="subtitle">
      {ascensions.length - 1} difficulty modifiers that stack as you climb
    </p>
  </div>

  <div style="max-width: 700px; margin: 0 auto;">
    <p class="desc-text" style="margin-bottom: 1.5rem; font-size: 0.95rem; color: var(--text-muted);">
      Ascension is the difficulty scaling system in Slay the Spire 2.
      Each level adds a new modifier on top of all previous ones, making runs progressively harder.
      Ascension levels are unlocked per-character by winning a run at the current highest level.
    </p>

    <div style="display: flex; flex-direction: column; gap: 0.5rem;">
      {ascensions.map(asc => (
        <a href={`${base}ascensions/${asc.id}/`}
           class="card-entry"
           style="display: flex; align-items: baseline; gap: 1rem; padding: 0.75rem 1rem;">
          <div style="min-width: 2.5rem; text-align: right;">
            <span class={asc.data.level === 0 ? 'desc-green' : asc.data.level >= 8 ? 'desc-red' : 'desc-gold'}
                  style="font-weight: 700; font-size: 1.1rem;">
              {asc.data.level}
            </span>
          </div>
          <div>
            <h3 style="margin: 0; font-size: 0.95rem;">
              {asc.data.title}
            </h3>
            <div class="desc-text" style="font-size: 0.85rem; margin-top: 0.15rem; color: var(--text-muted);">
              {asc.data.description}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const monsters = await getCollection('monsters');
  return monsters.map(monster => ({
    params: { slug: monster.id },
    props: { monster },
  }));
}

const { monster } = Astro.props;
const hpDisplay = monster.data.min_hp === monster.data.max_hp
  ? String(monster.data.min_hp)
  : `${monster.data.min_hp} - ${monster.data.max_hp}`;

// Map intent types to icon paths
const INTENT_ICONS: Record<string, string> = {
  'attack': 'attack/intent_attack_1',
  'multi_attack': 'attack/intent_attack_5',
  'buff': 'intent_buff',
  'debuff': 'intent_debuff',
  'block': 'intent_defend',
  'defend': 'intent_defend',
  'stun': 'intent_stun',
  'sleep': 'intent_sleep',
  'summon': 'intent_summon',
  'heal': 'intent_heal',
  'escape': 'intent_escape',
  'status': 'intent_status_card',
  'death_blow': 'intent_death_blow',
  'hidden': 'intent_hidden',
};

// Format intent as readable text
function formatIntent(intent: { type: string; damage?: number; hits?: number; amount?: number }): string {
  switch (intent.type) {
    case 'attack':
      return intent.damage ? `Deal ${intent.damage} damage` : 'Attack';
    case 'multi_attack':
      if (intent.damage && intent.hits) return `Deal ${intent.damage} damage x${intent.hits}`;
      if (intent.damage) return `Deal ${intent.damage} damage (multi)`;
      return 'Multi-attack';
    case 'block':
    case 'defend':
      return intent.amount ? `Gain ${intent.amount} Block` : 'Block';
    case 'buff': return 'Buff';
    case 'debuff': return 'Debuff';
    case 'stun': return 'Stun';
    case 'sleep': return 'Sleeping';
    case 'summon': return 'Summon';
    case 'heal': return 'Heal';
    case 'escape': return 'Escape';
    case 'death_blow': return 'Death Blow';
    case 'status': return 'Add Status';
    case 'hidden': return 'Hidden';
    default: return intent.type;
  }
}
---

<BaseLayout title={monster.data.title}>
  <div class="card-detail">
    <div class="card-header">
      <a href={`${import.meta.env.BASE_URL}monsters/`} style="font-size: 0.85rem;">&larr; All Monsters</a>
      <h1>{monster.data.title}</h1>
      <div class="card-meta">
        HP: {hpDisplay}
        {monster.data.is_companion && ' · Companion'}
      </div>
    </div>

    {monster.data.powers_on_spawn.length > 0 && (
      <div style="margin: 1rem 0;">
        <strong>Powers on spawn:</strong> {monster.data.powers_on_spawn.join(', ')}
      </div>
    )}

    {monster.data.moves.length > 0 && (
      <>
        <h2 style="margin-top: 1.5rem;">Moveset</h2>
        {monster.data.move_pattern && (
          <p style="margin: 0.5rem 0; color: var(--text-muted); font-size: 0.9rem;">{monster.data.move_pattern}</p>
        )}
        <table class="stat-table" style="margin-top: 0.5rem;">
          <thead>
            <tr>
              <th style="width: 36px;"></th>
              <th>Move</th>
              <th>Intent</th>
              <th>Details</th>
            </tr>
          </thead>
          <tbody>
            {monster.data.moves.map(move => (
              <tr>
                <td style="padding: 0.4rem;">
                  <div style="display: flex; gap: 2px;">
                    {move.intents.map(intent => {
                      const iconPath = INTENT_ICONS[intent.type];
                      return iconPath ? (
                        <img
                          src={`${import.meta.env.BASE_URL}images/intent_atlas/${iconPath}.png`}
                          alt={intent.type}
                          style="width: 24px; height: 24px;"
                          onerror="this.style.display='none'" />
                      ) : null;
                    })}
                  </div>
                </td>
                <td><strong>{move.title}</strong></td>
                <td>
                  {move.intents.map(intent => formatIntent(intent)).join(', ')}
                </td>
                <td style="color: var(--text-muted); font-size: 0.9rem;">
                  {move.effects.length > 0 ? move.effects.join('. ') : ''}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </>
    )}

    {monster.data.encounters.length > 0 && (
      <>
        <h2 style="margin-top: 1.5rem;">Appears In</h2>
        <ul style="margin: 0.5rem 0; padding-left: 1.5rem;">
          {monster.data.encounters.map(enc => (
            <li><a href={`${import.meta.env.BASE_URL}encounters/${enc.slug}/`}>{enc.title}</a></li>
          ))}
        </ul>
      </>
    )}
  </div>
</BaseLayout>

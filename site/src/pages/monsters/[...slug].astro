---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const monsters = await getCollection('monsters');
  return monsters.map(monster => ({
    params: { slug: monster.id },
    props: { monster },
  }));
}

const { monster } = Astro.props;
const hpDisplay = monster.data.min_hp === monster.data.max_hp
  ? String(monster.data.min_hp)
  : `${monster.data.min_hp} - ${monster.data.max_hp}`;

// Build power slug lookup for linking
const allPowers = await getCollection('powers');
const powerSlugs: Record<string, string> = {};
for (const p of allPowers) {
  powerSlugs[p.data.title.toLowerCase()] = p.id;
  // Also map class name without "Power" suffix
  const shortName = p.data.class_name.replace(/Power$/, '');
  powerSlugs[shortName.toLowerCase()] = p.id;
}

// Convert effect text to HTML with linked effect names
function linkEffects(effect: string): string {
  // Match "Apply N EffectName" or "Gain N EffectName" patterns
  return effect.replace(
    /(?:Apply|Gain)\s+(\d+)\s+(\w[\w\s]*\w|\w+)/g,
    (match, amount, name) => {
      const slug = powerSlugs[name.toLowerCase()];
      if (slug) {
        return `${match.startsWith('Apply') ? 'Apply' : 'Gain'} <span class="desc-red">${amount}</span> <a href="${import.meta.env.BASE_URL}powers/${slug}/" class="desc-gold">${name}</a>`;
      }
      return match;
    }
  );
}
---

<BaseLayout title={monster.data.title}>
  <div class="card-detail" style="max-width: 900px;">
    <div class="card-header">
      <a href={`${import.meta.env.BASE_URL}monsters/`} style="font-size: 0.85rem;">&larr; All Monsters</a>
      <h1>{monster.data.title} <span class="card-meta" style="font-weight: normal;">({hpDisplay} HP)</span></h1>
    </div>

    {monster.data.moves.length > 0 && (
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 1rem; align-items: start;">
        {/* Left column: Moves table */}
        <div style="border: 1px solid var(--border); border-radius: 8px; overflow: hidden;">
          <table style="width: 100%; border-collapse: collapse;">
            <tbody>
              {monster.data.moves.map(move => (
                <tr style="border-bottom: 1px solid var(--border);">
                  <td style="padding: 0.6rem 0.75rem; font-weight: 600; white-space: nowrap; width: 40%;">
                    {move.title}
                  </td>
                  <td style="padding: 0.6rem 0.75rem;">
                    {move.intents.map(intent => {
                      if ((intent.type === 'attack' || intent.type === 'multi_attack') && intent.damage) {
                        const dmgText = intent.type === 'multi_attack' && intent.hits
                          ? `${intent.damage}x${intent.hits}`
                          : String(intent.damage);
                        return <span class="desc-red">{dmgText}</span>;
                      }
                      if (intent.type === 'block' && intent.amount) {
                        return <span class="desc-blue">Block {intent.amount}</span>;
                      }
                      if (intent.type === 'buff') return <span class="desc-gold">Buff</span>;
                      if (intent.type === 'debuff') return <span class="desc-purple">Debuff</span>;
                      if (intent.type === 'stun') return <span class="desc-blue">Stun</span>;
                      if (intent.type === 'sleep') return <span class="desc-blue">Sleep</span>;
                      if (intent.type === 'summon') return <span class="desc-green">Summon</span>;
                      if (intent.type === 'heal') return <span class="desc-green">Heal</span>;
                      if (intent.type === 'escape') return <span>Escape</span>;
                      if (intent.type === 'status') return <span class="desc-purple">Status</span>;
                      return <span>{intent.type}</span>;
                    }).reduce((prev: any, curr: any, i: number) => i === 0 ? [curr] : [...prev, '  ', curr], [] as any[])}
                    {move.effects.length > 0 && (
                      <div style="margin-top: 0.25rem; font-size: 0.85rem;">
                        {move.effects.map(e => (
                          <span set:html={linkEffects(e)} style="margin-right: 0.5rem;" />
                        ))}
                      </div>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        {/* Right column: Behavior notes */}
        <div style="font-size: 0.9rem; color: var(--text-muted);">
          {monster.data.move_pattern && (
            <p style="margin-bottom: 1rem;">{monster.data.move_pattern}</p>
          )}

          {monster.data.powers_on_spawn.length > 0 && (
            <p>
              <strong>Innate:</strong>{' '}
              {monster.data.powers_on_spawn.map((power, i) => {
                const slug = powerSlugs[power.toLowerCase()];
                return (
                  <>
                    {i > 0 && ', '}
                    {slug
                      ? <a href={`${import.meta.env.BASE_URL}powers/${slug}/`} class="desc-gold">{power}</a>
                      : <span class="desc-gold">{power}</span>
                    }
                  </>
                );
              })}
            </p>
          )}

          {monster.data.is_companion && (
            <p style="margin-top: 0.5rem;"><em>This is a player companion, not an enemy.</em></p>
          )}
        </div>
      </div>
    )}

    {monster.data.encounters.length > 0 && (
      <>
        <h2 style="margin-top: 1.5rem;">Appears In</h2>
        <ul style="margin: 0.5rem 0; padding-left: 1.5rem;">
          {monster.data.encounters.map(enc => (
            <li><a href={`${import.meta.env.BASE_URL}encounters/${enc.slug}/`}>{enc.title}</a></li>
          ))}
        </ul>
      </>
    )}
  </div>
</BaseLayout>

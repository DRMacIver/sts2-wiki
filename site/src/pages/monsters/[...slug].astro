---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const monsters = await getCollection('monsters');
  return monsters.map(monster => ({
    params: { slug: monster.id },
    props: { monster },
  }));
}

const { monster } = Astro.props;
const hpDisplay = monster.data.min_hp === monster.data.max_hp
  ? String(monster.data.min_hp)
  : `${monster.data.min_hp} - ${monster.data.max_hp}`;

// Map intent types to icon paths (relative to intent_atlas/)
function intentIconPath(type: string): string {
  const map: Record<string, string> = {
    'attack': 'attack/intent_attack_1',
    'multi_attack': 'attack/intent_attack_5',
    'buff': 'intent_buff',
    'debuff': 'intent_debuff',
    'block': 'intent_defend',
    'defend': 'intent_defend',
    'stun': 'intent_stun',
    'sleep': 'intent_sleep',
    'summon': 'intent_summon',
    'heal': 'intent_heal',
    'escape': 'intent_escape',
    'status': 'intent_status_card',
    'death_blow': 'intent_death_blow',
  };
  return map[type] || 'intent_unknown';
}

function intentDisplay(intent: { type: string; damage?: number; hits?: number; amount?: number }): string {
  if ((intent.type === 'attack' || intent.type === 'multi_attack') && intent.damage) {
    if (intent.type === 'multi_attack' && intent.hits) {
      return `${intent.damage} x ${intent.hits}`;
    }
    return `${intent.damage}`;
  }
  if (intent.type === 'block' && intent.amount) {
    return `${intent.amount}`;
  }
  return '';
}
---

<BaseLayout title={monster.data.title}>
  <div class="card-detail">
    <div class="card-header">
      <a href={`${import.meta.env.BASE_URL}monsters/`} style="font-size: 0.85rem;">&larr; All Monsters</a>
      <h1>{monster.data.title}</h1>
      <div class="card-meta">
        HP: {hpDisplay}
        {monster.data.is_companion && ' · Companion'}
      </div>
    </div>

    {monster.data.powers_on_spawn.length > 0 && (
      <div style="margin: 1rem 0;">
        <strong>Powers on spawn:</strong> {monster.data.powers_on_spawn.join(', ')}
      </div>
    )}

    {monster.data.moves.length > 0 && (
      <>
        <h2 style="margin-top: 1.5rem;">Moveset</h2>
        <div style="margin-top: 0.5rem;">
          {monster.data.moves.map(move => (
            <div class="card-entry" style="margin-bottom: 0.5rem; display: flex; gap: 1rem; align-items: flex-start;">
              <div style="display: flex; gap: 0.25rem; flex-shrink: 0; min-width: 40px;">
                {move.intents.map(intent => (
                  <img
                    src={`${import.meta.env.BASE_URL}images/intent_atlas/${intentIconPath(intent.type)}.png`}
                    alt={intent.type}
                    style="width: 28px; height: 28px;"
                    onerror="this.style.display='none'" />
                ))}
              </div>
              <div style="flex: 1;">
                <div style="display: flex; gap: 0.75rem; align-items: baseline;">
                  <strong>{move.title || move.id}</strong>
                  <span class="card-meta">
                    {move.intents.map(intent => {
                      const val = intentDisplay(intent);
                      const label = intent.type === 'multi_attack' ? 'Attack' : intent.type.charAt(0).toUpperCase() + intent.type.slice(1);
                      return val ? `${label} ${val}` : label;
                    }).join(' + ')}
                  </span>
                </div>
                {move.effects.length > 0 && (
                  <div style="margin-top: 0.25rem; color: var(--text-muted); font-size: 0.9rem;">
                    {move.effects.join(', ')}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </>
    )}

    {monster.data.encounters.length > 0 && (
      <>
        <h2 style="margin-top: 1.5rem;">Appears In</h2>
        <ul style="margin: 0.5rem 0; padding-left: 1.5rem;">
          {monster.data.encounters.map(enc => (
            <li><a href={`${import.meta.env.BASE_URL}encounters/${enc.slug}/`}>{enc.title}</a></li>
          ))}
        </ul>
      </>
    )}
  </div>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { cleanDescription, charClass } from '../../utils';

export async function getStaticPaths() {
  const cards = await getCollection('cards');
  return cards.map(card => ({
    params: { slug: card.id },
    props: { card },
  }));
}

const { card } = Astro.props;
const { Content } = await render(card);

const costDisplay = card.data.x_cost ? 'X' : card.data.energy_cost >= 0 ? String(card.data.energy_cost) : 'Unplayable';
const hasStarCost = card.data.star_cost != null || card.data.x_star_cost;
const starCostDisplay = card.data.x_star_cost ? 'X' : card.data.star_cost != null ? String(card.data.star_cost) : null;

const charDir = card.data.character.toLowerCase();
const cardFileName = card.data.class_name.replace(/([A-Z])/g, (m: string, p1: string, offset: number) => (offset > 0 ? '_' : '') + p1).toLowerCase();
const cardArtPath = `${import.meta.env.BASE_URL}images/card_atlas/${charDir}/${cardFileName}.png`;
const cardArtBetaPath = `${import.meta.env.BASE_URL}images/card_atlas/${charDir}/beta/${cardFileName}.png`;

const descHtml = cleanDescription(card.data.description_html || card.data.description_plain);
const upgradedHtml = cleanDescription(card.data.upgraded_description_html || '');
---

<BaseLayout title={card.data.title}>
  <div class="card-detail">
    <a href={`${import.meta.env.BASE_URL}cards/`} class="back-link">&larr; All Cards</a>

    <div class="card-header">
      <div class="item-row" style="margin-top: 0.5rem;">
        <img src={cardArtPath} alt={card.data.title}
          class="card-art"
          onerror={`this.onerror=()=>{this.style.display='none'};this.src='${cardArtBetaPath}'`} />
        <div>
          <h1 style="display: flex; align-items: center; gap: 0.5rem;">
            {card.data.title}
            <span class="energy-cost">{costDisplay}</span>
            {hasStarCost && <span class="star-cost">{starCostDisplay}</span>}
          </h1>
          <div class="card-meta" style="font-size: 0.9rem;">
            <span class={charClass(card.data.character)}>{card.data.character}</span>
            · {card.data.type}
            · <span class={`rarity-${card.data.rarity.toLowerCase()}`}>{card.data.rarity}</span>
            {card.data.unlocked_by && (
              <> · Unlocked by {card.data.unlocked_by} epoch</>
            )}
          </div>
        </div>
      </div>
    </div>

    <table class="stat-table">
      <tr><th>Cost</th><td>{costDisplay}{hasStarCost && ` + ${starCostDisplay} Stars`}</td></tr>
      <tr><th>Type</th><td>{card.data.type}</td></tr>
      <tr><th>Rarity</th><td><span class={`rarity-${card.data.rarity.toLowerCase()}`}>{card.data.rarity}</span></td></tr>
      <tr><th>Target</th><td>{card.data.target}</td></tr>
      {card.data.keywords.length > 0 && (
        <tr><th>Keywords</th><td>{card.data.keywords.map(k => <span class="tag" style="margin-right: 0.25rem;">{k}</span>)}</td></tr>
      )}
    </table>

    {descHtml && (
      <>
        <h2 class="section-heading">Description</h2>
        <div class="desc-text" style="font-size: 1.05rem;" set:html={descHtml} />
      </>
    )}

    {upgradedHtml && (
      <>
        <h2 class="section-heading">Upgraded</h2>
        <div class="desc-text" style="font-size: 1.05rem;" set:html={upgradedHtml} />
        {card.data.upgraded_cost !== undefined && card.data.upgraded_cost !== card.data.energy_cost && (
          <p class="card-meta" style="margin-top: 0.5rem;">Cost: {card.data.upgraded_cost}</p>
        )}
      </>
    )}

    {card.data.notes && (
      <>
        <h2 class="section-heading">Notes</h2>
        <div class="desc-text" style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.6;">
          {card.data.notes}
        </div>
      </>
    )}

    {card.data.referenced_powers.length > 0 && (
      <>
        <h2 class="section-heading">Related Effects</h2>
        <ul class="linked-list">
          {card.data.referenced_powers.map(p => (
            <li><a href={`${import.meta.env.BASE_URL}powers/${p.slug}/`}>{p.title}</a></li>
          ))}
        </ul>
      </>
    )}

    <div style="margin-top: 2rem;">
      <Content />
    </div>
  </div>
</BaseLayout>

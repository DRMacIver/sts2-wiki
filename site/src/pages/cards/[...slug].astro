---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const cards = await getCollection('cards');
  return cards.map(card => ({
    params: { slug: card.id },
    props: { card },
  }));
}

const { card } = Astro.props;
const { Content } = await render(card);

const costDisplay = card.data.x_cost ? 'X' : card.data.energy_cost >= 0 ? String(card.data.energy_cost) : 'Unplayable';

// Build card art path: images/card_atlas/character/snake_case_name.png
const charDir = card.data.character.toLowerCase();
const cardFileName = card.data.class_name.replace(/([A-Z])/g, (m: string, p1: string, offset: number) => (offset > 0 ? '_' : '') + p1).toLowerCase();
const cardArtPath = `${import.meta.env.BASE_URL}images/card_atlas/${charDir}/${cardFileName}.png`;
---

<BaseLayout title={card.data.title}>
  <div class="card-detail">
    <div class="card-header">
      <a href={`${import.meta.env.BASE_URL}cards/`} style="font-size: 0.85rem;">&larr; All Cards</a>
      <div style="display: flex; gap: 1.5rem; align-items: flex-start; margin-top: 0.5rem;">
        <img src={cardArtPath} alt={card.data.title}
          style="width: 250px; border-radius: 6px; flex-shrink: 0;"
          onerror="this.style.display='none'" />
        <div>
          <h1 style="margin: 0;">{card.data.title}</h1>
          <div class="card-meta">{card.data.character} &middot; {card.data.type} &middot; <span class={`rarity-${card.data.rarity.toLowerCase()}`}>{card.data.rarity}</span></div>
        </div>
      </div>
    </div>

    <table class="stat-table">
      <tr><th>Cost</th><td>{costDisplay}</td></tr>
      <tr><th>Type</th><td>{card.data.type}</td></tr>
      <tr><th>Rarity</th><td>{card.data.rarity}</td></tr>
      <tr><th>Target</th><td>{card.data.target}</td></tr>
      {card.data.keywords.length > 0 && (
        <tr><th>Keywords</th><td>{card.data.keywords.join(', ')}</td></tr>
      )}
    </table>

    <h2 style="margin-top: 1.5rem;">Description</h2>
    <div style="margin: 0.75rem 0; font-size: 1.1rem;" set:html={card.data.description_html || card.data.description_plain} />

    {card.data.upgraded_description_html && (
      <>
        <h2 style="margin-top: 1.5rem;">Upgraded</h2>
        <div style="margin: 0.75rem 0; font-size: 1.1rem;" set:html={card.data.upgraded_description_html} />
        {card.data.upgraded_cost !== undefined && card.data.upgraded_cost !== card.data.energy_cost && (
          <p class="card-meta">Cost: {card.data.upgraded_cost}</p>
        )}
      </>
    )}

    {card.data.vars.length > 0 && (
      <>
        <h2 style="margin-top: 1.5rem;">Values</h2>
        <table class="stat-table">
          <tr><th>Variable</th><th>Base</th><th>Upgraded</th></tr>
          {card.data.vars.map(v => (
            <tr>
              <td>{v.type}</td>
              <td>{v.base_value}</td>
              <td>{v.upgraded_value !== undefined ? v.upgraded_value : '-'}</td>
            </tr>
          ))}
        </table>
      </>
    )}

    {card.data.referenced_powers.length > 0 && (
      <>
        <h2 style="margin-top: 1.5rem;">Related Effects</h2>
        <ul style="margin: 0.5rem 0; padding-left: 1.5rem;">
          {card.data.referenced_powers.map(p => (
            <li><a href={`${import.meta.env.BASE_URL}powers/${p.slug}/`}>{p.title}</a></li>
          ))}
        </ul>
      </>
    )}

    <div style="margin-top: 2rem;">
      <Content />
    </div>
  </div>
</BaseLayout>

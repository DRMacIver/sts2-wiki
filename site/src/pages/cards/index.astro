---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allCards = await getCollection('cards');
const cards = allCards.sort((a, b) => a.data.title.localeCompare(b.data.title));

const characters = [...new Set(cards.map(c => c.data.character))].sort();
const types = [...new Set(cards.map(c => c.data.type))].sort();
const rarities = ['Basic', 'Common', 'Uncommon', 'Rare'];
---

<BaseLayout title="Cards">
  <h1>Cards</h1>
  <p class="card-meta" style="margin-bottom: 1rem;">{cards.length} cards</p>

  <div class="filters">
    <strong style="align-self: center;">Character:</strong>
    {characters.map(ch => (
      <button class="filter-btn" data-filter="character" data-value={ch}>{ch}</button>
    ))}
  </div>
  <div class="filters">
    <strong style="align-self: center;">Type:</strong>
    {types.map(t => (
      <button class="filter-btn" data-filter="type" data-value={t}>{t}</button>
    ))}
  </div>
  <div class="filters">
    <strong style="align-self: center;">Rarity:</strong>
    {rarities.map(r => (
      <button class="filter-btn" data-filter="rarity" data-value={r}>{r}</button>
    ))}
  </div>

  <div class="card-grid" id="card-grid">
    {cards.map(card => (
      <a href={`${import.meta.env.BASE_URL}cards/${card.id}/`}
         class="card-entry"
         data-character={card.data.character}
         data-type={card.data.type}
         data-rarity={card.data.rarity}>
        <h3>
          <span class={`rarity-${card.data.rarity.toLowerCase()}`}>{card.data.title}</span>
          {card.data.x_cost
            ? <span class="card-meta"> X</span>
            : card.data.energy_cost >= 0
              ? <span class="card-meta"> {card.data.energy_cost}</span>
              : <span class="card-meta"> -</span>
          }
        </h3>
        <div class="card-meta">
          {card.data.character} &middot; {card.data.type} &middot; {card.data.rarity}
        </div>
        <div set:html={card.data.description_html || card.data.description_plain} />
      </a>
    ))}
  </div>

  <script>
    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.card-entry');
    const activeFilters: Record<string, string | null> = {};

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = (btn as HTMLElement).dataset.filter!;
        const value = (btn as HTMLElement).dataset.value!;

        if (activeFilters[filter] === value) {
          activeFilters[filter] = null;
          btn.classList.remove('active');
        } else {
          document.querySelectorAll(`[data-filter="${filter}"]`).forEach(b => b.classList.remove('active'));
          activeFilters[filter] = value;
          btn.classList.add('active');
        }

        cards.forEach(card => {
          const el = card as HTMLElement;
          let visible = true;
          for (const [f, v] of Object.entries(activeFilters)) {
            if (v && el.dataset[f] !== v) visible = false;
          }
          el.style.display = visible ? '' : 'none';
        });
      });
    });
  </script>
</BaseLayout>

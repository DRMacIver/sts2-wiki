---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { monsterImageName } from '../../utils';

export async function getStaticPaths() {
  const encounters = await getCollection('encounters');
  return encounters.map(enc => ({
    params: { slug: enc.id },
    props: { enc },
  }));
}

const { enc } = Astro.props;
const base = import.meta.env.BASE_URL;

// Build monster lookup for link validation and image mapping
const allMonsters = await getCollection('monsters');
const monsterBySlug: Record<string, { className: string; title: string }> = {};
for (const m of allMonsters) {
  monsterBySlug[m.id] = { className: m.data.class_name, title: m.data.title };
}
---

<BaseLayout title={enc.data.title}>
  <div class="card-detail">
    <a href={`${base}encounters/`} class="back-link">&larr; All Encounters</a>

    <div class="card-header">
      <h1>{enc.data.title}</h1>
      <div class="card-meta" style="font-size: 0.9rem;">
        <span class={enc.data.room_type === 'Boss' ? 'desc-red' : enc.data.room_type === 'Elite' ? 'desc-orange' : ''}>
          {enc.data.room_type}
        </span>
        {enc.data.is_weak && ' (Weak)'}
        {enc.data.acts.length > 0 && ` · ${enc.data.acts.join(', ')}`}
      </div>
    </div>

    <h2 class="section-heading">Monsters</h2>
    <div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 0.5rem;">
      {enc.data.monsters.map(m => {
        const monster = monsterBySlug[m.slug];
        const imgName = monster ? monsterImageName(monster.className) : m.slug;
        return (
          <div style="display: flex; gap: 0.75rem; align-items: center; background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 0.75rem 1rem; min-width: 200px;">
            <img
              src={`${base}images/monsters/${imgName}.png`}
              alt="" style="width: 48px; height: 48px; object-fit: contain; flex-shrink: 0;"
              onerror="this.style.display='none'" />
            {monster
              ? <a href={`${base}monsters/${m.slug}/`} style="font-weight: 500;">{m.title}</a>
              : <span style="font-weight: 500;">{m.title}</span>
            }
          </div>
        );
      })}
    </div>

    {enc.data.tags.length > 0 && (
      <div style="margin-top: 1rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
        {enc.data.tags.map(t => (
          <span class="tag">{t}</span>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

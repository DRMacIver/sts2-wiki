---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { encounterHref } from '../../utils';

const base = import.meta.env.BASE_URL;

const allEncounters = (await getCollection('encounters'))
  .filter(e => !e.data.class_name.includes('Deprecated'));
const encounters = allEncounters.sort((a, b) => a.data.title.localeCompare(b.data.title));
const monsterIds = new Set((await getCollection('monsters')).map(m => m.id));

const roomTypes = ['Monster', 'Elite', 'Boss'];
---

<BaseLayout title="Encounters">
  <div class="page-header">
    <h1>Encounters</h1>
    <p class="subtitle">{encounters.length} encounters across 4 acts</p>
  </div>

  <div class="filters">
    <span class="filter-label">Type</span>
    {roomTypes.map(t => (
      <button class="filter-btn" data-filter="roomtype" data-value={t}>{t}</button>
    ))}
  </div>

  <div class="card-grid" id="enc-grid">
    {encounters.map(enc => (
      <a href={encounterHref(enc, base, monsterIds)}
         class="card-entry"
         data-roomtype={enc.data.room_type}>
        <h3>
          {enc.data.title}
          {enc.data.is_weak && <span class="tag" style="margin-left: 0.5rem; font-size: 0.7rem;">Weak</span>}
        </h3>
        <div class="card-meta">
          <span class={enc.data.room_type === 'Boss' ? 'desc-red' : enc.data.room_type === 'Elite' ? 'desc-orange' : ''}>
            {enc.data.room_type}
          </span>
          {enc.data.acts.length > 0 && ` · ${enc.data.acts.join(', ')}`}
        </div>
        <div class="card-meta" style="margin-top: 0.25rem;">
          {enc.data.monsters.map(m => m.title).join(', ')}
        </div>
      </a>
    ))}
  </div>

  <script>
    const buttons = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('#enc-grid .card-entry');
    const activeFilters: Record<string, string | null> = {};

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = (btn as HTMLElement).dataset.filter!;
        const value = (btn as HTMLElement).dataset.value!;
        if (activeFilters[filter] === value) {
          activeFilters[filter] = null;
          btn.classList.remove('active');
        } else {
          document.querySelectorAll(`[data-filter="${filter}"]`).forEach(b => b.classList.remove('active'));
          activeFilters[filter] = value;
          btn.classList.add('active');
        }
        items.forEach(item => {
          const el = item as HTMLElement;
          let visible = true;
          for (const [f, v] of Object.entries(activeFilters)) {
            if (v && el.dataset[f] !== v) visible = false;
          }
          el.style.display = visible ? '' : 'none';
        });
      });
    });
  </script>
</BaseLayout>

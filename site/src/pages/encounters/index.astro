---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allEncounters = await getCollection('encounters');
const encounters = allEncounters.sort((a, b) => a.data.title.localeCompare(b.data.title));

const roomTypes = ['Monster', 'Elite', 'Boss'];
---

<BaseLayout title="Encounters">
  <h1>Encounters</h1>
  <p class="card-meta" style="margin-bottom: 1rem;">{encounters.length} encounters</p>

  <div class="filters">
    <strong style="align-self: center;">Type:</strong>
    {roomTypes.map(t => (
      <button class="filter-btn" data-filter="roomType" data-value={t}>{t}</button>
    ))}
  </div>

  <div class="card-grid" id="enc-grid">
    {encounters.map(enc => (
      <a href={`${import.meta.env.BASE_URL}encounters/${enc.id}/`}
         class="card-entry"
         data-room-type={enc.data.room_type}>
        <h3>
          {enc.data.title}
          {enc.data.is_weak && <span class="card-meta"> (Weak)</span>}
        </h3>
        <div class="card-meta">
          {enc.data.room_type}
          {enc.data.acts.length > 0 && ` · ${enc.data.acts.join(', ')}`}
        </div>
        <div class="card-meta" style="margin-top: 0.25rem;">
          {enc.data.monsters.map(m => m.title).join(', ')}
        </div>
      </a>
    ))}
  </div>

  <script>
    const buttons = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('.card-entry');
    const activeFilters: Record<string, string | null> = {};

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = (btn as HTMLElement).dataset.filter!;
        const value = (btn as HTMLElement).dataset.value!;

        if (activeFilters[filter] === value) {
          activeFilters[filter] = null;
          btn.classList.remove('active');
        } else {
          document.querySelectorAll(`[data-filter="${filter}"]`).forEach(b => b.classList.remove('active'));
          activeFilters[filter] = value;
          btn.classList.add('active');
        }

        items.forEach(item => {
          const el = item as HTMLElement;
          let visible = true;
          for (const [f, v] of Object.entries(activeFilters)) {
            if (v && el.dataset[f.replace(/([A-Z])/g, (m) => m.toLowerCase())] !== v) visible = false;
          }
          el.style.display = visible ? '' : 'none';
        });
      });
    });
  </script>
</BaseLayout>

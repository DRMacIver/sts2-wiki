---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const ancients = await getCollection('ancients');
  return ancients.map(ancient => ({
    params: { slug: ancient.id },
    props: { ancient },
  }));
}

const { ancient } = Astro.props;
---

<BaseLayout title={ancient.data.title}>
  <div class="card-detail">
    <div class="card-header">
      <a href={`${import.meta.env.BASE_URL}ancients/`} style="font-size: 0.85rem;">&larr; All Ancients</a>
      <h1>{ancient.data.title}</h1>
      {ancient.data.epithet && (
        <div class="card-meta" style="font-style: italic;">{ancient.data.epithet}</div>
      )}
    </div>

    {ancient.data.acts.length > 0 && (
      <div style="margin: 1rem 0;">
        <strong>Acts:</strong> {ancient.data.acts.join(', ')}
      </div>
    )}

    {ancient.data.relic_offerings.length > 0 && (
      <>
        <h2 style="margin-top: 1.5rem;">Relic Offerings</h2>
        <div class="card-grid" style="margin-top: 0.75rem;">
          {ancient.data.relic_offerings.map(relic => (
            <a href={`${import.meta.env.BASE_URL}relics/${relic.slug}/`} class="card-entry" style="display: flex; gap: 0.75rem; align-items: flex-start;">
              <img
                src={`${import.meta.env.BASE_URL}images/relic_atlas/${relic.image || relic.slug.replace(/-/g, '_')}.png`}
                alt={relic.title}
                style="width: 48px; height: 48px; flex-shrink: 0; image-rendering: pixelated;"
                onerror="this.style.display='none'" />
              <div>
                <h3 style="margin: 0; font-size: 1rem;">{relic.title}</h3>
                {relic.description && (
                  <p class="card-meta" style="margin-top: 0.25rem;">{relic.description}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </>
    )}
  </div>
</BaseLayout>

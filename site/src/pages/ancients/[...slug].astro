---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { cleanDescription } from '../../utils';

export async function getStaticPaths() {
  const ancients = await getCollection('ancients');
  return ancients.map(ancient => ({
    params: { slug: ancient.id },
    props: { ancient },
  }));
}

const { ancient } = Astro.props;
---

<BaseLayout title={ancient.data.title}>
  <div class="card-detail">
    <a href={`${import.meta.env.BASE_URL}ancients/`} class="back-link">&larr; All Ancients</a>

    <div class="card-header">
      <div class="item-row" style="align-items: center; margin-top: 0.5rem;">
        <img
          src={`${import.meta.env.BASE_URL}images/ancients/${ancient.id}.png`}
          alt={ancient.data.title}
          class="item-icon-lg"
          style="width: 80px; height: 80px; object-fit: contain; border-radius: 50%;"
          onerror="this.style.display='none'" />
        <div>
          <h1 class="desc-gold">{ancient.data.title}</h1>
          {ancient.data.epithet && (
            <div class="card-meta" style="font-style: italic; font-size: 1rem;">{ancient.data.epithet}</div>
          )}
        </div>
      </div>
    </div>

    {ancient.data.acts.length > 0 && (
      <div style="margin: 1rem 0; display: flex; gap: 0.5rem;">
        {ancient.data.acts.map(act => (
          <span class="tag">{act}</span>
        ))}
      </div>
    )}

    {ancient.data.relic_offerings.length > 0 && (
      <>
        <h2 class="section-heading">Relic Offerings</h2>
        <div class="card-grid compact" style="margin-top: 0.75rem;">
          {ancient.data.relic_offerings.map(relic => (
            <a href={`${import.meta.env.BASE_URL}relics/${relic.slug}/`} class="card-entry" style="display: flex; gap: 0.75rem; align-items: flex-start;">
              <img
                src={`${import.meta.env.BASE_URL}images/relic_atlas/${relic.image || relic.slug.replace(/-/g, '_')}.png`}
                alt={relic.title}
                class="item-icon"
                onerror="this.style.display='none'" />
              <div>
                <h3 style="font-size: 0.95rem;">{relic.title}</h3>
                {relic.description && (
                  <p class="card-meta" style="margin-top: 0.25rem;" set:html={cleanDescription(relic.description)} />
                )}
              </div>
            </a>
          ))}
        </div>
      </>
    )}
  </div>
</BaseLayout>

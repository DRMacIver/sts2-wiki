---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { cleanDescription } from '../../utils';

const allPowers = await getCollection('powers');
const powers = allPowers.sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<BaseLayout title="Effects">
  <div class="page-header">
    <h1>Effects</h1>
    <p class="subtitle">{powers.length} buffs and debuffs</p>
  </div>

  <div class="filters">
    <span class="filter-label">Type</span>
    <button class="filter-btn" data-filter="powertype" data-value="Buff">Buff</button>
    <button class="filter-btn" data-filter="powertype" data-value="Debuff">Debuff</button>
  </div>

  <div class="card-grid" id="power-grid">
    {powers.map(power => {
      const iconName = power.data.class_name.replace(/([A-Z])/g, (m: string, p1: string, offset: number) => (offset > 0 ? '_' : '') + p1).toLowerCase();
      return (
        <a href={`${import.meta.env.BASE_URL}powers/${power.id}/`}
           class="card-entry"
           data-powertype={power.data.power_type}
           style="display: flex; gap: 0.75rem; align-items: flex-start;">
          <img
            src={`${import.meta.env.BASE_URL}images/power_atlas/${iconName}.png`}
            alt="" style="width: 32px; height: 32px; flex-shrink: 0; margin-top: 0.25rem; image-rendering: pixelated;"
            onerror="this.style.display='none'" />
          <div>
            <h3 style="margin: 0;">
              <span class={power.data.power_type === 'Debuff' ? 'desc-red' : 'desc-gold'}>{power.data.title}</span>
            </h3>
            <div class="card-meta">
              {power.data.power_type} · {power.data.stack_type}
            </div>
            <div class="desc-text" style="font-size: 0.85rem; margin-top: 0.25rem;" set:html={cleanDescription(power.data.description_html || power.data.description_plain)} />
          </div>
        </a>
      );
    })}
  </div>

  <script>
    const buttons = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('#power-grid .card-entry');
    const activeFilters: Record<string, string | null> = {};

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = (btn as HTMLElement).dataset.filter!;
        const value = (btn as HTMLElement).dataset.value!;
        if (activeFilters[filter] === value) {
          activeFilters[filter] = null;
          btn.classList.remove('active');
        } else {
          document.querySelectorAll(`[data-filter="${filter}"]`).forEach(b => b.classList.remove('active'));
          activeFilters[filter] = value;
          btn.classList.add('active');
        }
        items.forEach(item => {
          const el = item as HTMLElement;
          let visible = true;
          for (const [f, v] of Object.entries(activeFilters)) {
            if (v && el.dataset[f] !== v) visible = false;
          }
          el.style.display = visible ? '' : 'none';
        });
      });
    });
  </script>
</BaseLayout>

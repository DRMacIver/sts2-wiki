---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allEpochs = await getCollection('epochs');
// Group by story
const byStory: Record<string, typeof allEpochs> = {};
for (const epoch of allEpochs) {
  const story = epoch.data.story || 'Other';
  if (!byStory[story]) byStory[story] = [];
  byStory[story].push(epoch);
}
// Sort each group by era_position
for (const story of Object.keys(byStory)) {
  byStory[story].sort((a, b) => a.data.era_position - b.data.era_position);
}
const storyOrder = ['Ironclad', 'Silent', 'Defect', 'Necrobinder', 'Regent', 'Colorless', 'Event', 'Relic', 'Potion', 'Other'];
const sortedStories = Object.keys(byStory).sort((a, b) => {
  const ai = storyOrder.indexOf(a);
  const bi = storyOrder.indexOf(b);
  return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
});
---

<BaseLayout title="Epochs">
  <div class="page-header">
    <h1>Epochs</h1>
    <p class="subtitle">{allEpochs.length} unlock progression milestones</p>
  </div>

  {sortedStories.map(story => (
    <>
      <h2 style="margin-top: 2rem;">
        <span class={`char-${story.toLowerCase()}`}>{story}</span>
      </h2>
      <div class="card-grid" style="margin-top: 0.75rem;">
        {byStory[story].map(epoch => {
          const unlockCount = epoch.data.unlocks_cards.length + epoch.data.unlocks_relics.length +
            epoch.data.unlocks_events.length + epoch.data.unlocks_encounters.length;
          return (
            <a href={`${import.meta.env.BASE_URL}epochs/${epoch.id}/`} class="card-entry" style="display: flex; gap: 0.75rem;">
              <img
                src={`${import.meta.env.BASE_URL}images/epoch_atlas/${epoch.data.image}.png`}
                alt="" style="width: 64px; height: 64px; object-fit: cover; border-radius: 4px; flex-shrink: 0;"
                onerror="this.style.display='none'" loading="lazy" />
              <div>
                <h3 style="margin: 0; font-size: 0.95rem;">{epoch.data.title}</h3>
                <div class="card-meta">{epoch.data.era} · Position {epoch.data.era_position}</div>
                {unlockCount > 0 && (
                  <div style="margin-top: 0.25rem; font-size: 0.8rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
                    {epoch.data.unlocks_cards.length > 0 && <span class="tag">{epoch.data.unlocks_cards.length} cards</span>}
                    {epoch.data.unlocks_relics.length > 0 && <span class="tag">{epoch.data.unlocks_relics.length} relics</span>}
                    {epoch.data.unlocks_events.length > 0 && <span class="tag">{epoch.data.unlocks_events.length} events</span>}
                    {epoch.data.unlocks_encounters.length > 0 && <span class="tag">{epoch.data.unlocks_encounters.length} encounters</span>}
                  </div>
                )}
              </div>
            </a>
          );
        })}
      </div>
    </>
  ))}
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allEpochs = await getCollection('epochs');
// Group by story
const byStory: Record<string, typeof allEpochs> = {};
for (const epoch of allEpochs) {
  const story = epoch.data.story || 'Other';
  if (!byStory[story]) byStory[story] = [];
  byStory[story].push(epoch);
}
// Sort each group by era_position
for (const story of Object.keys(byStory)) {
  byStory[story].sort((a, b) => a.data.era_position - b.data.era_position);
}
const storyOrder = ['Ironclad', 'Silent', 'Defect', 'Necrobinder', 'Regent', 'Colorless', 'Event', 'Relic', 'Potion', 'Other'];
const sortedStories = Object.keys(byStory).sort((a, b) => {
  const ai = storyOrder.indexOf(a);
  const bi = storyOrder.indexOf(b);
  return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
});
---

<BaseLayout title="Epochs">
  <h1>Epochs</h1>
  <p class="card-meta" style="margin-bottom: 1rem;">{allEpochs.length} epochs — unlock progression</p>

  {sortedStories.map(story => (
    <>
      <h2 style="margin-top: 1.5rem;">{story}</h2>
      <div class="card-grid" style="margin-top: 0.5rem;">
        {byStory[story].map(epoch => (
          <a href={`${import.meta.env.BASE_URL}epochs/${epoch.id}/`} class="card-entry">
            <h3 style="margin: 0;">{epoch.data.title}</h3>
            <div class="card-meta">{epoch.data.era} — Position {epoch.data.era_position}</div>
            <div style="margin-top: 0.25rem; font-size: 0.85rem;">
              {epoch.data.unlocks_cards.length > 0 && <span>{epoch.data.unlocks_cards.length} cards </span>}
              {epoch.data.unlocks_relics.length > 0 && <span>{epoch.data.unlocks_relics.length} relics </span>}
              {epoch.data.unlocks_events.length > 0 && <span>{epoch.data.unlocks_events.length} events </span>}
              {epoch.data.unlocks_encounters.length > 0 && <span>{epoch.data.unlocks_encounters.length} encounters </span>}
            </div>
          </a>
        ))}
      </div>
    </>
  ))}
</BaseLayout>

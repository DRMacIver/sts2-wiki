---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allRelics = await getCollection('relics');
const relics = allRelics.sort((a, b) => a.data.title.localeCompare(b.data.title));

const rarities = ['Starter', 'Common', 'Uncommon', 'Rare', 'Shop', 'Event', 'Ancient'];
---

<BaseLayout title="Relics">
  <h1>Relics</h1>
  <p class="card-meta" style="margin-bottom: 1rem;">{relics.length} relics</p>

  <div class="filters">
    <strong style="align-self: center;">Rarity:</strong>
    {rarities.map(r => (
      <button class="filter-btn" data-filter="rarity" data-value={r}>{r}</button>
    ))}
  </div>

  <div class="card-grid" id="relic-grid">
    {relics.map(relic => (
      <a href={`${import.meta.env.BASE_URL}relics/${relic.id}/`}
         class="card-entry"
         data-rarity={relic.data.rarity}
         style="display: flex; gap: 0.75rem; align-items: flex-start;">
        <img
          src={`${import.meta.env.BASE_URL}images/relic_atlas/${relic.data.image}.png`}
          alt="" style="width: 40px; height: 40px; flex-shrink: 0; image-rendering: pixelated;"
          onerror="this.style.display='none'" loading="lazy" />
        <div>
          <h3 style="margin: 0;">
            <span class={`rarity-${relic.data.rarity.toLowerCase()}`}>{relic.data.title}</span>
          </h3>
          <div class="card-meta">{relic.data.rarity}{relic.data.pool && relic.data.pool !== 'Shared' && relic.data.pool !== 'Unknown' ? ` · ${relic.data.pool}` : ''}</div>
          <div set:html={relic.data.description_html || relic.data.description_plain} style="font-size: 0.9rem;" />
        </div>
      </a>
    ))}
  </div>

  <script>
    const buttons = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('.card-entry');
    const activeFilters: Record<string, string | null> = {};

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = (btn as HTMLElement).dataset.filter!;
        const value = (btn as HTMLElement).dataset.value!;
        if (activeFilters[filter] === value) {
          activeFilters[filter] = null;
          btn.classList.remove('active');
        } else {
          document.querySelectorAll(`[data-filter="${filter}"]`).forEach(b => b.classList.remove('active'));
          activeFilters[filter] = value;
          btn.classList.add('active');
        }
        items.forEach(item => {
          const el = item as HTMLElement;
          let visible = true;
          for (const [f, v] of Object.entries(activeFilters)) {
            if (v && el.dataset[f] !== v) visible = false;
          }
          el.style.display = visible ? '' : 'none';
        });
      });
    });
  </script>
</BaseLayout>

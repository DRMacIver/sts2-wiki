---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { cleanDescription } from '../../utils';

export async function getStaticPaths() {
  const relics = await getCollection('relics');
  return relics.map(relic => ({
    params: { slug: relic.id },
    props: { relic },
  }));
}

const { relic } = Astro.props;
---

<BaseLayout title={relic.data.title}>
  <div class="card-detail">
    <a href={`${import.meta.env.BASE_URL}relics/`} class="back-link">&larr; All Relics</a>

    <div class="card-header">
      <div class="item-row" style="align-items: center; margin-top: 0.5rem;">
        <img
          src={`${import.meta.env.BASE_URL}images/relic_atlas/${relic.data.image}.png`}
          alt={relic.data.title}
          class="item-icon-lg"
          onerror="this.style.display='none'" />
        <div>
          <h1>{relic.data.title}</h1>
          <div class="card-meta" style="font-size: 0.9rem;">
            <span class={`rarity-${relic.data.rarity.toLowerCase()}`}>{relic.data.rarity}</span>
            {relic.data.pool && relic.data.pool !== 'Shared' && relic.data.pool !== 'Unknown' && (
              <> · {relic.data.pool}</>
            )}
          </div>
        </div>
      </div>
    </div>

    <h2 class="section-heading">Description</h2>
    <div class="desc-text" style="font-size: 1.05rem;" set:html={cleanDescription(relic.data.description_html || relic.data.description_plain)} />

    {relic.data.flavor && (
      <p class="flavor">{relic.data.flavor}</p>
    )}

    <table class="stat-table" style="margin-top: 1.5rem;">
      <tr><th>Rarity</th><td><span class={`rarity-${relic.data.rarity.toLowerCase()}`}>{relic.data.rarity}</span></td></tr>
      {relic.data.character && (
        <tr><th>Character</th><td>{relic.data.character} only</td></tr>
      )}
      {relic.data.pool && relic.data.pool !== 'Shared' && relic.data.pool !== 'Unknown' && !relic.data.character && (
        <tr><th>Pool</th><td>{relic.data.pool}</td></tr>
      )}
      {relic.data.sources.length > 0 && (
        <tr><th>Sources</th><td>{relic.data.sources.join(', ')}</td></tr>
      )}
    </table>
  </div>
</BaseLayout>
